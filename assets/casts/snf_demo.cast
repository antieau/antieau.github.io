[0.0, "o", "\u001b[2J\u001b[H\r\n\r\n\r\n\u001b[1m\u001b[94m   \u2554\u2550\u2557 \u2554\u2557  \u2554\u2550\u2550 \u2554\u2550\u2557 \u2566\u2550\u2557 \u2554\u2550\u2557 \u2554\u2550\u2557 \u2566   \u2554\u2550\u2557 \u001b[0m\r\n\u001b[1m\u001b[94m   \u255a\u2550\u2557 \u2551\u255a\u2557 \u2560\u2550\u2550 \u2551 \u2551 \u2560\u2566\u255d \u2560\u2550\u2563 \u2551   \u2551   \u2560\u2550  \u001b[0m\r\n\u001b[1m\u001b[94m   \u255a\u2550\u255d \u255d  \u255d\u2569   \u255a\u2550\u255d \u2569\u255a\u2550 \u2569 \u2569 \u255a\u2550\u255d \u255a\u2550\u2550 \u255a\u2550\u255d \u001b[0m\r\n\r\n   \u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\r\n   \u001b[96mSmith Normal Form \u00b7 Hermite Normal Form \u00b7 Elementary Divisors\u001b[0m\r\n   for  \u2124  \u00b7  F_p  \u00b7  F_p[x]  \u2014  pluggable multi-backend Python API\r\n\r\n   \u001b[93mBackends:\u001b[0m  PARI/GP (cypari2)  \u00b7  FLINT (python-flint)\r\n              \u001b[37mSageMath  \u00b7  MAGMA  \u00b7  pure Python (reference)\u001b[0m\r\n\r\n\r\n\r\n"]
[3.0, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[44m\u001b[96m START \u001b[0m                                                     \r\n\r\n  \u001b[93m\u001b[1mStep 0/11  \u00b7  Initial matrix\u001b[0m\r\n  \u001b[37mGoal: find diagonal D and invertible U, V  with  D = U\u00b7M\u00b7V\u001b[0m\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502   2\u001b[0m \u2502   2\u001b[0m \u2502   5\u001b[0m \u2502       \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   1\u001b[0m \u2502   3\u001b[0m \u2502  -1\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   3\u001b[0m \u2502   6\u001b[0m \u2502  11\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n\r\n\r\n\r\n"]
[5.5, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[43m NEXT \u001b[0m                                                      \r\n\r\n  \u001b[93m\u001b[1mStep 1/11  \u00b7  \u25b6 Swap row 0 \u2194 row 1\u001b[0m\r\n  \u001b[37mMove smallest |1| to pivot: swap row 0 \u2194 row 1\u001b[0m\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502 \u001b[45m  2\u001b[0m \u2502 \u001b[45m  2\u001b[0m \u2502 \u001b[45m  5\u001b[0m \u2502       \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502 \u001b[104m  1\u001b[0m \u2502 \u001b[104m  3\u001b[0m \u2502 \u001b[104m -1\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   3\u001b[0m \u2502   6\u001b[0m \u2502  11\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n  \u001b[43m   \u001b[0m pivot    \u001b[100m   \u001b[0m source row/col    \u001b[46m   \u001b[0m target row/col    \u001b[45m   \u001b[0m/\u001b[104m   \u001b[0m swap pair    \u001b[92m\u25a0\u001b[0m done diagonal\r\n\r\n\r\n"]
[7.7, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[42m\u001b[97m OK \u001b[0m                                                        \r\n\r\n  \u001b[93m\u001b[1mStep 1/11  \u00b7  \u2713 Swap row 0 \u2194 row 1\u001b[0m\r\n\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502   1\u001b[0m \u2502   3\u001b[0m \u2502  -1\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   2\u001b[0m \u2502   2\u001b[0m \u2502   5\u001b[0m \u2502       \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   3\u001b[0m \u2502   6\u001b[0m \u2502  11\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n\r\n\r\n\r\n"]
[9.1, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[43m NEXT \u001b[0m                                                      \r\n\r\n  \u001b[93m\u001b[1mStep 2/11  \u00b7  \u25b6 Row 1 \u2190 Row 1 \u2212 2\u00b7Row 0\u001b[0m\r\n  \u001b[37mRow 1 \u2190 Row 1 \u2212 2\u00b7Row 0   (zeros out M[1][0] = 2)\u001b[0m\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502 \u001b[43m  1\u001b[0m \u2502 \u001b[100m  3\u001b[0m \u2502 \u001b[100m -1\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502 \u001b[46m  2\u001b[0m \u2502 \u001b[46m  2\u001b[0m \u2502 \u001b[46m  5\u001b[0m \u2502       \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   3\u001b[0m \u2502   6\u001b[0m \u2502  11\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n  \u001b[43m   \u001b[0m pivot    \u001b[100m   \u001b[0m source row/col    \u001b[46m   \u001b[0m target row/col    \u001b[45m   \u001b[0m/\u001b[104m   \u001b[0m swap pair    \u001b[92m\u25a0\u001b[0m done diagonal\r\n\r\n\r\n"]
[11.3, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[42m\u001b[97m OK \u001b[0m                                                        \r\n\r\n  \u001b[93m\u001b[1mStep 2/11  \u00b7  \u2713 Row 1 \u2190 Row 1 \u2212 2\u00b7Row 0\u001b[0m\r\n\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502   1\u001b[0m \u2502   3\u001b[0m \u2502  -1\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -4\u001b[0m \u2502   7\u001b[0m \u2502       \u2502  1\u001b[0m \u2502 -2\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   3\u001b[0m \u2502   6\u001b[0m \u2502  11\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n\r\n\r\n\r\n"]
[12.7, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[43m NEXT \u001b[0m                                                      \r\n\r\n  \u001b[93m\u001b[1mStep 3/11  \u00b7  \u25b6 Row 2 \u2190 Row 2 \u2212 3\u00b7Row 0\u001b[0m\r\n  \u001b[37mRow 2 \u2190 Row 2 \u2212 3\u00b7Row 0   (zeros out M[2][0] = 3)\u001b[0m\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502 \u001b[43m  1\u001b[0m \u2502 \u001b[100m  3\u001b[0m \u2502 \u001b[100m -1\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -4\u001b[0m \u2502   7\u001b[0m \u2502       \u2502  1\u001b[0m \u2502 -2\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502 \u001b[46m  3\u001b[0m \u2502 \u001b[46m  6\u001b[0m \u2502 \u001b[46m 11\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n  \u001b[43m   \u001b[0m pivot    \u001b[100m   \u001b[0