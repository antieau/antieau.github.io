[22.1, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[42m\u001b[97m OK \u001b[0m                                                        \r\n\r\n  \u001b[93m\u001b[1mStep 5/11  \u00b7  \u2713 Col 2 \u2190 Col 2 \u2212 -1\u00b7Col 0\u001b[0m\r\n\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502       \u2502  0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   1\u001b[0m \u2502  -3\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -4\u001b[0m \u2502   7\u001b[0m \u2502       \u2502  1\u001b[0m \u2502 -2\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -3\u001b[0m \u2502  14\u001b[0m \u2502       \u2502  0\u001b[0m \u2502 -3\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n\r\n\r\n\r\n\r\n"]
[23.5, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[43m NEXT \u001b[0m                                                      \r\n\r\n  \u001b[93m\u001b[1mStep 6/11  \u00b7  \u25b6 Swap row 1 \u2194 row 2\u001b[0m\r\n  \u001b[37mMove smallest |-3| to pivot: swap row 1 \u2194 row 2\u001b[0m\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502 \u001b[92m  1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502       \u2502 \u001b[92m 0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502 \u001b[92m  1\u001b[0m \u2502  -3\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2502 \u001b[45m  0\u001b[0m \u2502 \u001b[45m -4\u001b[0m \u2502 \u001b[45m  7\u001b[0m \u2502       \u2502  1\u001b[0m \u2502 -2\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502 \u001b[104m  0\u001b[0m \u2502 \u001b[104m -3\u001b[0m \u2502 \u001b[104m 14\u001b[0m \u2502       \u2502  0\u001b[0m \u2502 -3\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n  \u001b[2mInvariant factors (1 so far):  \u001b[92m\u001b[1m1\u001b[0m\r\n\r\n  \u001b[43m   \u001b[0m pivot    \u001b[100m   \u001b[0m source row/col    \u001b[46m   \u001b[0m target row/col    \u001b[45m   \u001b[0m/\u001b[104m   \u001b[0m swap pair    \u001b[92m\u25a0\u001b[0m done diagonal\r\n\r\n"]
[25.7, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[42m\u001b[97m OK \u001b[0m                                                        \r\n\r\n  \u001b[93m\u001b[1mStep 6/11  \u00b7  \u2713 Swap row 1 \u2194 row 2\u001b[0m\r\n\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502 \u001b[92m  1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502       \u2502 \u001b[92m 0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502 \u001b[92m  1\u001b[0m \u2502  -3\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -3\u001b[0m \u2502  14\u001b[0m \u2502       \u2502  0\u001b[0m \u2502 -3\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -4\u001b[0m \u2502   7\u001b[0m \u2502       \u2502  1\u001b[0m \u2502 -2\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n  \u001b[2mInvariant factors (1 so far):  \u001b[92m\u001b[1m1\u001b[0m\r\n\r\n\r\n\r\n"]
[27.1, "o", "\u001b[2J\u001b[H\u001b[44m\u001b[97m\u001b[1m  Smith Normal Form \u2014 step by step  \u001b[0m  \u001b[43m NEXT \u001b[0m                                                      \r\n\r\n  \u001b[93m\u001b[1mStep 7/11  \u00b7  \u25b6 Negate row 1\u001b[0m\r\n  \u001b[37mMake pivot positive: negate row 1  (was -3)\u001b[0m\r\n\r\n  \u001b[2mM  (working matrix)\u001b[0m       \u001b[2mU  (left transform)\u001b[0m       \u001b[2mV  (right transform)\u001b[0m\r\n  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510       \u250c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2510          \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2510 \r\n  \u2502 \u001b[92m  1\u001b[0m \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502       \u2502 \u001b[92m 0\u001b[0m \u2502  1\u001b[0m \u2502  0\u001b[0m \u2502          \u2502 \u001b[92m  1\u001b[0m \u2502  -3\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2502 \u001b[100m  0\u001b[0m \u2502 \u001b[100m -3\u001b[0m \u2502 \u001b[100m 14\u001b[0m \u2502       \u2502  0\u001b[0m \u2502 -3\u001b[0m \u2502  1\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502   0\u001b[0m \u2502 \r\n  \u2502   0\u001b[0m \u2502  -4\u001b[0m \u2502   7\u001b[0m \u2502       \u2502  1\u001b[0m \u2502 -2\u001b[0m \u2502  0\u001b[0m \u2502          \u2502   0\u001b[0m \u2502   0\u001b[0m \u2502   1\u001b[0m \u2502 \r\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518       \u2514\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2518          \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518 \r\n\r\n  \u001b[2mInvariant factors (1 so far):  \u001b[92m\u001b[1m1\u001b[0m\r\n\r\n  \u001b[43m   \u001b[0m pivot    \u001b[100m   \u001b[0m source row/col    \u001b[46m   \u001b[0m target row/col    \u001b[45m   \u001b[0m/\u001b[104m   \u001b[0m swap pair    \u001b[92m\u25a0\u001b[0m done diagonal\r\n\r\n"]
